-- Main Script (Locked Up)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
while not player do task.wait() player = Players.LocalPlayer end
local playerGui = player:WaitForChild("PlayerGui")
local camera = workspace.CurrentCamera

FOV_RADIUS = 100
SMOOTHNESS = 0.80
AIM_ANGLE_OFFSET = 10.5
AIMBOT_ENABLED = true
GRAY_SKYBOX_ENABLED = false
HIDE_TAG_ENABLED = false
WANTED_ONLY = false
TARGET_UI_ENABLED = true
IGNORE_FRIENDS = true
local MOUSE_LOCKED = false

TARGET_ON_PLAYER = nil  
local target = nil

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FOVGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local fovCircle = Instance.new("Frame", screenGui)
fovCircle.Size = UDim2.new(0, FOV_RADIUS*2, 0, FOV_RADIUS*2)
fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
fovCircle.Position = UDim2.new(0.5, 0, 0.5, 0)
fovCircle.BackgroundColor3 = Color3.fromRGB(0,255,0)
fovCircle.BackgroundTransparency = 1
fovCircle.BorderSizePixel = 0
Instance.new("UICorner", fovCircle).CornerRadius = UDim.new(1,0)
local uiStroke = Instance.new("UIStroke", fovCircle)
uiStroke.Name = "FOVStroke"
uiStroke.Color = Color3.fromRGB(0, 255, 0)
uiStroke.Thickness = 1
fovCircle.Visible = AIMBOT_ENABLED

local function isVisible(targetCharacter)
	if not targetCharacter then return false end
	local hrp = targetCharacter:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end
	local origin = camera.CFrame.Position
	local direction = hrp.Position - origin
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	params.FilterDescendantsInstances = {player.Character, targetCharacter}
	return Workspace:Raycast(origin, direction, params) == nil
end

local function getClosestInFOV()
	if TARGET_ON_PLAYER then
		local targetPlr = Players:FindFirstChild(TARGET_ON_PLAYER)
		if targetPlr and targetPlr.Character then
			local humanoid = targetPlr.Character:FindFirstChildOfClass("Humanoid")
			local hrp = targetPlr.Character:FindFirstChild("HumanoidRootPart")
			if humanoid and humanoid.Health > 0 and hrp then
				if WANTED_ONLY and targetPlr.Team and targetPlr.Team.Name == "Inmates" then
					local head = targetPlr.Character:FindFirstChild("Head")
					if head then
						local bb = head:FindFirstChild("OverheadBBGUI")
						if bb and bb:IsA("BillboardGui") then
							local wanted = bb:FindFirstChild("WantedTag")
							if wanted and wanted:IsA("TextLabel") then
								if not wanted.Visible then
									return nil
								end
							else
								return nil
							end
						else
							return nil
						end
					end
				end
				local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
				if onScreen and isVisible(targetPlr.Character) then
					return targetPlr
				end
			end
		end
		return nil
	end

	local closest = nil
	local shortestDistance = math.huge
	local screenCenter = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local myTeam = player.Team
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			if IGNORE_FRIENDS and player:IsFriendsWith(plr.UserId) then
				continue
			end
			
			if myTeam and plr.Team == myTeam then continue end
			
			if myTeam then
				local myTeamName = myTeam.Name
				local plrTeamName = plr.Team and plr.Team.Name
				if (myTeamName == "Guards" and plrTeamName == "Warden") or (myTeamName == "Warden" and plrTeamName == "Guards") then
					continue
				end
			end
			
			local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
			local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
			if humanoid and humanoid.Health > 0 and hrp then
				if WANTED_ONLY and plr.Team and plr.Team.Name == "Inmates" then
					local head = plr.Character:FindFirstChild("Head")
					if head then
						local bb = head:FindFirstChild("OverheadBBGUI")
						if bb and bb:IsA("BillboardGui") then
							local wanted = bb:FindFirstChild("WantedTag")
							if wanted and wanted:IsA("TextLabel") then
								if not wanted.Visible then
									continue
								end
							end
						end
					end
				end
				local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
				if onScreen then
					local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
					if dist < FOV_RADIUS and dist < shortestDistance then
						if isVisible(plr.Character) then
							closest = plr
							shortestDistance = dist
						end
					end
				end
			end
		end
	end
	return closest
end

RunService.RenderStepped:Connect(function()
	if not AIMBOT_ENABLED then
		if MOUSE_LOCKED then
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			MOUSE_LOCKED = false
		end
		_G.updateTargetInfo(nil)
		return
	end
	target = getClosestInFOV()
	if target and target.Character then
		local hrp = target.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			local camPos = camera.CFrame.Position
			local lookAtHRP = CFrame.new(camPos, hrp.Position)
			local adjustedCFrame = lookAtHRP * CFrame.Angles(math.rad(-AIM_ANGLE_OFFSET), 0, 0)
			camera.CFrame = camera.CFrame:Lerp(adjustedCFrame, SMOOTHNESS)
			if not MOUSE_LOCKED then
				UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
				MOUSE_LOCKED = true
			end
		end
		_G.updateTargetInfo(target)
	else
		if MOUSE_LOCKED then
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			MOUSE_LOCKED = false
		end
		_G.updateTargetInfo(nil)
	end
end)

-- Funções compartilhadas
function enableGraySkybox()
	local lighting = game:GetService("Lighting")
	pcall(function() if lighting:FindFirstChild("GraySky") then lighting.GraySky:Destroy() end end)
	local sky = Instance.new("Sky", lighting)
	sky.Name = "GraySky"
	sky.SkyboxBk = "rbxassetid://154987705"
	sky.SkyboxDn = "rbxassetid://154987705"
	sky.SkyboxFt = "rbxassetid://154987705"
	sky.SkyboxLf = "rbxassetid://154987705"
	sky.SkyboxRt = "rbxassetid://154987705"
	sky.SkyboxUp = "rbxassetid://154987705"
end

function disableGraySkybox()
	local lighting = game:GetService("Lighting")
	pcall(function() if lighting:FindFirstChild("GraySky") then lighting.GraySky:Destroy() end end)
	pcall(function() lighting.Sky = nil end)
end

function updateTagVisibility()
	local char = player.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if not head then return end
	for _, name in ipairs({"Hostile", "KillstreakHeadGui", "OverheadBBGUI"}) do
		local billboard = head:FindFirstChild(name)
		if billboard and billboard:IsA("BillboardGui") then
			billboard.Enabled = not HIDE_TAG_ENABLED
		end
	end
end

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.E then
		AIMBOT_ENABLED = not AIMBOT_ENABLED
		if _G.updateAimbotState then _G.updateAimbotState() end
	end
end)

player.CharacterAdded:Connect(function()
	camera.CameraType = Enum.CameraType.Custom
	UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	MOUSE_LOCKED = false
	if HIDE_TAG_ENABLED then
		task.wait(0.5)
		updateTagVisibility()
	end
end)

_G.updateSmooth = function(delta)
	SMOOTHNESS = math.clamp(SMOOTHNESS + delta, 0.01, 1)
	if _G.smoothValueLabel then
		_G.smoothValueLabel.Text = string.format("%.2f", SMOOTHNESS)
	end
end

_G.updateAngle = function(delta)
	AIM_ANGLE_OFFSET = math.clamp(AIM_ANGLE_OFFSET + delta, 0, 15)
	if _G.angleValueLabel then
		_G.angleValueLabel.Text = string.format("%.1f°", AIM_ANGLE_OFFSET)
	end
end

_G.updateFOV = function(delta)
	FOV_RADIUS = math.clamp(FOV_RADIUS + delta, 30, 500)
	if _G.fovValueLabel then
		_G.fovValueLabel.Text = tostring(FOV_RADIUS)
	end
	if fovCircle then
		fovCircle.Size = UDim2.new(0, FOV_RADIUS*2, 0, FOV_RADIUS*2)
	end
end

-- ============ TARGET INFO UPDATE FUNCTION ============
_G.updateTargetInfo = function(targetPlayer)
	if not TARGET_UI_ENABLED then return end  
	
	local targetInfoFrame = playerGui:FindFirstChild("TargetInfoGui") and playerGui.TargetInfoGui:FindFirstChild("TargetInfoFrame")
	if not targetInfoFrame then return end
	
	if not targetPlayer or not targetPlayer.Character then
		targetInfoFrame.Visible = false
		return
	end
	
	local char = targetPlayer.Character
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not humanoid or not hrp then
		targetInfoFrame.Visible = false
		return
	end
	
	targetInfoFrame.Visible = true
	
	local headshotImage = targetInfoFrame:FindFirstChild("Headshot")
	local usernameLabel = targetInfoFrame:FindFirstChild("Username")
	local healthLabel = targetInfoFrame:FindFirstChild("Health")
	local distanceLabel = targetInfoFrame:FindFirstChild("Distance")
	local healthBarFill = targetInfoFrame:FindFirstChild("HealthBarBg") and targetInfoFrame.HealthBarBg:FindFirstChild("HealthBarFill")
	
	if headshotImage then
		headshotImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=48&h=48&f=png"
	end
	if usernameLabel then
		usernameLabel.Text = targetPlayer.Name
	end
	
	local health, maxHealth = math.floor(humanoid.Health), math.floor(humanoid.MaxHealth)
	local hp = health / maxHealth
	
	if healthLabel then
		healthLabel.Text = health .. "/" .. maxHealth
		if hp > 0.6 then
			healthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
		elseif hp > 0.3 then
			healthLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
		else
			healthLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		end
	end
	
	if healthBarFill then
		if hp > 0.6 then
			healthBarFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		elseif hp > 0.3 then
			healthBarFill.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
		else
			healthBarFill.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
		end
		healthBarFill.Size = UDim2.new(hp, 0, 1, 0)
	end
	
	if distanceLabel then
		local myChar = player.Character
		if myChar and myChar:FindFirstChild("HumanoidRootPart") then
			local dist = (myChar.HumanoidRootPart.Position - hrp.Position).Magnitude
			distanceLabel.Text = string.format("%.0f studs", dist)
		else
			distanceLabel.Text = "? studs"
		end
	end
	
	local toolLabel = targetInfoFrame:FindFirstChild("Tool")
	if toolLabel then
		local tool = char:FindFirstChildOfClass("Tool")
		if tool then
			toolLabel.Text = "Tool: " .. tool.Name
			toolLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
		else
			toolLabel.Text = "Tool: None"
			toolLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
		end
	end
end

_G.refreshTargetOnList = function(dropdownFrame)
	for _, child in ipairs(dropdownFrame:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	
	local noneBtn = Instance.new("TextButton", dropdownFrame)
	noneBtn.Size = UDim2.new(1, 0, 0, 22)
	noneBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	noneBtn.Text = "None"
	noneBtn.Font = Enum.Font.Gotham
	noneBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
	noneBtn.TextSize = 10
	noneBtn.BorderSizePixel = 0
	noneBtn.MouseButton1Click:Connect(function()
		TARGET_ON_PLAYER = nil
		dropdownFrame.Parent.Visible = false
		_G.targetOnLabel.Text = "Target On: None"
	end)
	
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local plrBtn = Instance.new("TextButton", dropdownFrame)
			plrBtn.Size = UDim2.new(1, 0, 0, 22)
			plrBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
			plrBtn.Text = plr.Name
			plrBtn.Font = Enum.Font.Gotham
			plrBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
			plrBtn.TextSize = 10
			plrBtn.BorderSizePixel = 0
			plrBtn.MouseButton1Click:Connect(function()
				TARGET_ON_PLAYER = plr.Name
				dropdownFrame.Parent.Visible = false
				_G.targetOnLabel.Text = "Target On: " .. plr.Name
			end)
		end
	end
end

