function applyTextureSkin(tool, skinId)
    if not skinId or skinId == "" then return end
    
    for _, part in ipairs(tool:GetDescendants()) do
        if part.Name == "Muzzle" then continue end
        if not part:IsA("BasePart") then continue end
        
        local firstTex = part:FindFirstChild("Skin_Top")
        if firstTex and firstTex:IsA("Texture") and firstTex.Texture == skinId then
            continue  
        end
        
        for _, face in ipairs(faceNames) do
            local existing = part:FindFirstChild("Skin_" .. face)
            if existing then existing:Destroy() end
        end
        
        for _, face in ipairs(faceNames) do
            local tex = Instance.new("Texture")
            tex.Name = "Skin_" .. face
            tex.Texture = skinId
            tex.Color3 = Color3.fromRGB(255, 255, 255)
            tex.StudsPerTileU = 3
            tex.StudsPerTileV = 3
            tex.Face = Enum.NormalId[face]
            tex.Parent = part
        end
    end
end

function applyMaterialSkin(tool, material, color)
    for _, part in ipairs(tool:GetDescendants()) do
        if not part:IsA("BasePart") then continue end
        
        if part.Material == material and part.Color == color then continue end
        
        for _, child in ipairs(part:GetChildren()) do
            if child:IsA("Texture") or child:IsA("Decal") then
                child:Destroy()
            end
        end
        
        if part:IsA("MeshPart") then
            part.TextureID = ""
        end
        
        part.Material = material
        part.Color = color
    end
end

function setWeaponSkin(name)
    local skinData = weaponSkins[name]
    if not skinData then return end
    
    if currentSkin == "Rainbow" and name ~= "Rainbow" then
        if rainbowConnection then
            rainbowConnection:Disconnect()
            rainbowConnection = nil
        end
    end
    
    if name == "Rainbow" and not rainbowConnection then
        rainbowConnection = RunService.RenderStepped:Connect(function()
            rainbowHue = (rainbowHue + 1) % 360
        end)
    end
    
    currentSkin = name
    skinApplyCount = {}  
    
    for tool, _ in pairs(activeSkinTools) do
        activeSkinTools[tool] = nil
    end
    
    if skinData.Type ~= "Default" then
        local char = player.Character
        if char then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                applySkinToTool(tool, skinData)
                activeSkinTools[tool] = true
                skinApplyCount[tool] = 1
            end
        end
        
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    applySkinToTool(tool, skinData)
                    activeSkinTools[tool] = true
                    skinApplyCount[tool] = 1
                end
            end
        end
    end
end

function applyRainbowSkin(tool)
    local color = Color3.fromHSV(rainbowHue / 360, 1, 1)
    for _, part in ipairs(tool:GetDescendants()) do
        if not part:IsA("BasePart") then continue end
        
        for _, child in ipairs(part:GetChildren()) do
            if child:IsA("Texture") or child:IsA("Decal") then
                child:Destroy()
            end
        end
        
        if part:IsA("MeshPart") then
            part.TextureID = ""
        end
        
        part.Material = Enum.Material.Neon
        part.Color = color
    end
end

function applySkinToTool(tool, skinData)
    if not skinData then return end
    
    if skinData.Type == "Texture" then
        applyTextureSkin(tool, skinData.Id)
    elseif skinData.Type == "Material" then
        applyMaterialSkin(tool, skinData.Material, skinData.Color)
    elseif skinData.Type == "Rainbow" then
        applyRainbowSkin(tool)
    end
end

