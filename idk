local function createVisualToggle(parent, posY, labelText, callback, categoryColor)
	local container = Instance.new("Frame", parent)
	container.Size = UDim2.new(0.88, 0, 0, 34)
	container.Position = UDim2.new(0.06, 0, 0, posY)
	container.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
	container.BorderSizePixel = 0
	Instance.new("UICorner", container).CornerRadius = UDim.new(0, 4)
	
	local label = Instance.new("TextLabel", container)
	label.Size = UDim2.new(0.6, 0, 1, 0)
	label.Position = UDim2.new(0, 10, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText .. ": OFF"
	label.TextColor3 = Color3.fromRGB(200, 200, 200)
	label.Font = Enum.Font.Gotham
	label.TextSize = 10
	label.TextXAlignment = Enum.TextXAlignment.Left
	
	local btn = Instance.new("TextButton", container)
	btn.Size = UDim2.new(0, 60, 0, 20)
	btn.Position = UDim2.new(1, -68, 0.5, 0)
	btn.AnchorPoint = Vector2.new(0, 0.5)
	btn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
	btn.Text = "Disabled"
	btn.Font = Enum.Font.Gotham
	btn.TextColor3 = Color3.fromRGB(20, 20, 20)
	btn.TextSize = 9
	btn.BorderSizePixel = 0
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)
	
	local isEnabled = false
	
	btn.MouseButton1Click:Connect(function()
		isEnabled = not isEnabled
		callback(isEnabled)
		if isEnabled then
			btn.Text = "Enabled"
			btn.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
			label.Text = labelText .. ": ON"
		else
			btn.Text = "Disabled"
			btn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
			label.Text = labelText .. ": OFF"
		end
	end)
	
	return btn
end

