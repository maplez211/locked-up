local function createToggleButton(parent, posY, text, getState, callback)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(0.88, 0, 0, 28)
	btn.Position = UDim2.new(0.06, 0, 0, posY)
	btn.Font = Enum.Font.Gotham
	btn.TextColor3 = Color3.fromRGB(20, 20, 20)
	btn.TextSize = 11
	btn.BorderSizePixel = 0
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
	
	local function updateVisual()
		local state = getState()
		btn.Text = text .. (state and ": ON" or ": OFF")
		btn.BackgroundColor3 = state and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
	end
	
	updateVisual()
	
	btn.MouseButton1Click:Connect(function()
		callback()
		updateVisual()
	end)
	
	return btn
end

