function applyShotSound(tool, soundId)
    local handle = tool:FindFirstChild("Handle")
    if not handle then return end
    
    local fireSound = handle:FindFirstChild("FireSound")
    if not fireSound then return end
    
    if soundId == "" then
        return
    end
    
    fireSound.SoundId = soundId
end

function setShotSound(name)
    local soundId = shotSounds[name]
    if soundId == nil then return end
    
    currentShotSound = soundId
    
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then applyShotSound(tool, soundId) end
    end
    
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then applyShotSound(tool, soundId) end
        end
    end
end

player.ChildAdded:Connect(function(child)  
    if child:IsA("Tool") and currentShotSound and currentShotSound ~= "" then
        task.wait(0.3)
        applyShotSound(child, currentShotSound)
    end
end)

backpack.ChildAdded:Connect(function(child)  
    if child:IsA("Tool") and currentShotSound and currentShotSound ~= "" then
        task.wait(0.3)
        applyShotSound(child, currentShotSound)
    end
end)

